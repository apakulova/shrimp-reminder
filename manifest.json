{
  "manifest_version": 3,
  "name": "Не будь креветкой",
  "description": "Регулярные заметные напоминания с заботой о себе во время работы",
  "version": "1.0.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "alarms",
    "idle",
    "notifications",
    "offscreen",
    "storage"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Не будь креветкой",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  }
}
